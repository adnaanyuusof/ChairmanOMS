@model ChairmanOMS.Models.UserViewModel
@{
    ViewData["Title"] = "Edit User";
}

<style>
    .page-header {
        background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
        border-radius: 1rem;
        padding: 1.5rem;
        color: #fff;
        margin-bottom: 1.5rem;
    }

    .page-header h2 {
        margin: 0;
        font-weight: 600;
    }

    .page-header p {
        margin: 0.25rem 0 0 0;
        opacity: 0.9;
        font-size: 0.9rem;
    }
</style>

<div class="page-header">
    <h2><i class="bi bi-person-gear me-2"></i>Edit User: @Model.FirstName @Model.LastName</h2>
    <p>Update user information and access roles</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="modern-card card shadow-sm border-0">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="mb-0 text-primary fw-bold"><i class="bi bi-person-circle me-2"></i>User Profile</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 p-2 bg-danger bg-opacity-10 rounded"></div>
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="FirstName" class="form-label fw-medium">First Name</label>
                            <input asp-for="FirstName" class="form-control" required />
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="LastName" class="form-label fw-medium">Last Name</label>
                            <input asp-for="LastName" class="form-control" required />
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-medium">Email Address</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope text-muted"></i></span>
                            <input asp-for="Email" type="email" class="form-control border-start-0" required />
                        </div>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Department" class="form-label fw-medium">Department</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="bi bi-building text-muted"></i></span>
                                <input asp-for="Department" class="form-control border-start-0" />
                            </div>
                            <span asp-validation-for="Department" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Role" class="form-label fw-medium">System Role</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="bi bi-shield-lock text-muted"></i></span>
                                <select asp-for="Role" class="form-select border-start-0" asp-items="@ViewBag.Roles" required>
                                    <option value="">Select a role</option>
                                </select>
                            </div>
                            <span asp-validation-for="Role" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch p-0 pt-2 ms-4">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" id="isActiveSwitch">
                            <label class="form-check-label fw-medium ms-2" for="isActiveSwitch">Account Active</label>
                        </div>
                    </div>

                    <hr class="my-4 text-muted opacity-25">

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label fw-medium text-warning">Reset Password <small class="text-muted fw-normal">(Leave blank to keep current password)</small></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-key text-muted"></i></span>
                            <input asp-for="Password" type="password" class="form-control border-start-0" placeholder="Enter new password to reset" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-end gap-2 pt-2">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 border-0">
                            Cancel
                        </a>
                        <button type="submit" class="btn btn-warning px-5 text-dark fw-bold shadow-sm">
                            <i class="bi bi-save me-1"></i> Update User Profile
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
