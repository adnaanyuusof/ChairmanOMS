@using ChairmanOMS.Models
@model IEnumerable<ApplicationUser>

@{
    ViewData["Title"] = "User Management";
    var userRoles = ViewBag.UserRoles as Dictionary<string, string> ?? new Dictionary<string, string>();
}

<style>
    .page-header {
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        border-radius: 1rem;
        padding: 1.5rem;
        color: #fff;
        margin-bottom: 1.5rem;
    }

    .page-header h2 {
        margin: 0;
        font-weight: 600;
    }

    .page-header p {
        margin: 0.25rem 0 0 0;
        opacity: 0.9;
        font-size: 0.9rem;
    }
</style>

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2><i class="bi bi-people-fill me-2"></i>User Management</h2>
        <p>Manage system users and their permissions</p>
    </div>
    <a asp-action="Create" class="btn btn-light">
        <i class="bi bi-plus-circle me-1"></i> Add New User
    </a>
</div>

<div class="modern-card">
    <div class="table-responsive">
        <table class="table modern-table mb-0">
            <thead>
                <tr>
                    <th><i class="bi bi-person me-1"></i>Name</th>
                    <th><i class="bi bi-envelope me-1"></i>Email</th>
                    <th><i class="bi bi-building me-1"></i>Department</th>
                    <th><i class="bi bi-shield me-1"></i>Role</th>
                    <th><i class="bi bi-toggle-on me-1"></i>Status</th>
                    <th><i class="bi bi-calendar me-1"></i>Created</th>
                    <th><i class="bi bi-gear me-1"></i>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="fw-medium">@user.FirstName @user.LastName</td>
                        <td><a href="mailto:@user.Email" class="text-decoration-none">@user.Email</a></td>
                        <td>@user.Department</td>
                        <td>
                            <span class="status-badge @(userRoles.ContainsKey(user.Id) && userRoles[user.Id] == "Admin" ? "bg-danger" : "bg-secondary")" style="background: #e0e7ff; color: #4f46e5;">
                                @(userRoles.ContainsKey(user.Id) ? userRoles[user.Id] : "None")
                            </span>
                        </td>
                        <td>
                            @if (user.IsActive)
                            {
                                <span class="status-badge status-delivered"><i class="bi bi-check-circle me-1"></i>Active</span>
                            }
                            else
                            {
                                <span class="status-badge status-rejected"><i class="bi bi-x-circle me-1"></i>Inactive</span>
                            }
                        </td>
                        <td class="text-muted">@user.CreatedAt.ToString("MMM d, yyyy")</td>
                        <td>
                            <form asp-action="ToggleStatus" asp-route-id="@user.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm @(user.IsActive ? "btn-outline-danger" : "btn-outline-success")">
                                    @(user.IsActive ? "Deactivate" : "Activate")
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
