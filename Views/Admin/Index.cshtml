@using ChairmanOMS.Models
@model IEnumerable<ApplicationUser>

@{
    ViewData["Title"] = "User Management";
    var userRoles = ViewBag.UserRoles as Dictionary<string, string> ?? new Dictionary<string, string>();
}

<style>
    .page-header {
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        border-radius: 1rem;
        padding: 1.5rem;
        color: #fff;
        margin-bottom: 1.5rem;
    }

    .page-header h2 {
        margin: 0;
        font-weight: 600;
    }

    .page-header p {
        margin: 0.25rem 0 0 0;
        opacity: 0.9;
        font-size: 0.9rem;
    }
</style>

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2><i class="bi bi-people-fill me-2"></i>User Management</h2>
        <p>Manage system users and their permissions</p>
    </div>
    <a asp-action="Create" class="btn btn-light">
        <i class="bi bi-plus-circle me-1"></i> Add New User
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4 border-0 shadow-sm" role="alert" style="background: #ecfdf5; color: #059669;">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4 border-0 shadow-sm" role="alert" style="background: #fef2f2; color: #dc2626;">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="modern-card">
    <div class="table-responsive">
        <table class="table modern-table mb-0">
            <thead>
                <tr>
                    <th><i class="bi bi-person me-1 text-primary"></i>Name</th>
                    <th><i class="bi bi-envelope me-1 text-primary"></i>Email</th>
                    <th><i class="bi bi-building me-1 text-primary"></i>Dept</th>
                    <th><i class="bi bi-shield me-1 text-primary"></i>Role</th>
                    <th><i class="bi bi-toggle-on me-1 text-primary"></i>Status</th>
                    <th><i class="bi bi-gear me-1 text-primary"></i>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-bold text-dark">@user.FirstName @user.LastName</div>
                            <small class="text-muted">ID: @user.Id.Substring(0, 8)...</small>
                        </td>
                        <td>@user.Email</td>
                        <td><span class="badge bg-light text-dark fw-normal border">@user.Department</span></td>
                        <td>
                            <span class="status-badge" style="background: @(userRoles.ContainsKey(user.Id) && userRoles[user.Id] == "Admin" ? "#fee2e2" : "#e0e7ff"); color: @(userRoles.ContainsKey(user.Id) && userRoles[user.Id] == "Admin" ? "#dc2626" : "#4f46e5");">
                                @(userRoles.ContainsKey(user.Id) ? userRoles[user.Id] : "None")
                            </span>
                        </td>
                        <td>
                            @if (user.IsActive)
                            {
                                <span class="badge rounded-pill bg-success bg-opacity-10 text-success px-3"><i class="bi bi-dot me-1"></i>Active</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-danger bg-opacity-10 text-danger px-3"><i class="bi bi-dot me-1"></i>Inactive</span>
                            }
                        </td>
                        <td>
                            <div class="btn-group shadow-sm">
                                <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-white btn-sm border" title="Edit Profile">
                                    <i class="bi bi-pencil-square text-warning"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@user.Id" method="post" onsubmit="return confirm('WARNING: This will permanently delete this user. Proceed?');" style="display:inline;">
                                    <button type="submit" class="btn btn-white btn-sm border" title="Permanently Delete">
                                        <i class="bi bi-trash3 text-danger"></i>
                                    </button>
                                </form>
                                <form asp-action="ToggleStatus" asp-route-id="@user.Id" method="post" style="display:inline;">
                                    <button type="submit" class="btn btn-white btn-sm border" title="@(user.IsActive ? "Deactivate" : "Activate")">
                                        <i class="bi @(user.IsActive ? "bi-person-slash text-danger" : "bi-person-check text-success")"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
