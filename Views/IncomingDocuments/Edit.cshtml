@model ChairmanOMS.Models.IncomingDocument
@{
    ViewData["Title"] = "Edit Incoming Document";
}

<div class="row justify-content-center mt-2">
    <div class="col-lg-9">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold">Edit Incoming Document (@Model.ReferenceNumber)</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="ReferenceNumber" class="form-label text-muted small fw-bold"></label>
                            <input asp-for="ReferenceNumber" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="SourceInstitution" class="form-label text-muted small fw-bold"></label>
                            <input asp-for="SourceInstitution" class="form-control" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Subject" class="form-label text-muted small fw-bold"></label>
                        <input asp-for="Subject" class="form-control" required />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="DateReceived" class="form-label text-muted small fw-bold"></label>
                            <input asp-for="DateReceived" type="date" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Priority" class="form-label text-muted small fw-bold"></label>
                            <select asp-for="Priority" class="form-select" asp-items="@ViewBag.Priorities"></select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="AssignedToUserId" class="form-label text-muted small fw-bold">Assign To</label>
                            <select asp-for="AssignedToUserId" asp-items="@ViewBag.Users" class="form-select">
                                <option value="">-- Unassigned --</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Status" class="form-label text-muted small fw-bold"></label>
                            <select asp-for="Status" class="form-select" asp-items="@ViewBag.Statuses"></select>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-muted small fw-bold">Update Attachment (Optional)</label>
                        <input type="file" name="attachment" class="form-control" accept=".pdf,.docx,.doc" />
                        @if (!string.IsNullOrEmpty(Model.AttachmentPath))
                        {
                            <small class="text-muted d-block mt-1">Current: <a href="@Model.AttachmentPath" target="_blank">View File</a></small>
                        }
                    </div>
                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-light">Cancel</a>
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
