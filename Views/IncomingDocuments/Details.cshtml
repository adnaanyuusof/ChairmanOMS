@model ChairmanOMS.Models.IncomingDocument
@{
    ViewData["Title"] = "Document Details";
}

<div class="row">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold">Incoming Document</h5>
                @{
                    var sClass = Model.Status == "Approved" ? "bg-success" : Model.Status == "Rejected" ? "bg-danger" : Model.Status == "Archived" ? "bg-dark" : "bg-info text-dark";
                }
                <span class="badge @sClass">@Model.Status</span>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Reference Number</dt>
                    <dd class="col-sm-8"><code>@Model.ReferenceNumber</code></dd>

                    <dt class="col-sm-4 text-muted">Source Institution</dt>
                    <dd class="col-sm-8">@Model.SourceInstitution</dd>

                    <dt class="col-sm-4 text-muted">Subject</dt>
                    <dd class="col-sm-8 fw-medium">@Model.Subject</dd>

                    <dt class="col-sm-4 text-muted">Date Received</dt>
                    <dd class="col-sm-8">@Model.DateReceived.ToLongDateString()</dd>

                    <dt class="col-sm-4 text-muted">Priority</dt>
                    <dd class="col-sm-8">
                        @{ var pClass = Model.Priority == "High" ? "bg-danger" : Model.Priority == "Medium" ? "bg-warning text-dark" : "bg-secondary"; }
                        <span class="badge @pClass">@Model.Priority</span>
                    </dd>

                    <dt class="col-sm-4 text-muted">Assigned To</dt>
                    <dd class="col-sm-8">@(Model.AssignedToUser?.Email ?? "Unassigned")</dd>

                    @if (!string.IsNullOrEmpty(Model.AttachmentPath))
                    {
                        <dt class="col-sm-4 text-muted">Attachment</dt>
                        <dd class="col-sm-8">
                            <a href="@Model.AttachmentPath" target="_blank" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-paperclip me-1"></i>Download
                            </a>
                        </dd>
                    }
                </dl>
            </div>
        </div>

        <!-- Workflow Timeline -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h6 class="mb-0 fw-bold">Workflow History</h6>
            </div>
            <div class="card-body pb-0">
                @if (Model.WorkflowActions.Any())
                {
                    <ul class="list-unstyled">
                        @foreach (var a in Model.WorkflowActions.OrderByDescending(x => x.CreatedAt))
                        {
                            var aClass = a.ActionTaken == "Approved" ? "text-success" : a.ActionTaken == "Rejected" ? "text-danger" : "text-info";
                            <li class="mb-3 d-flex gap-3">
                                <div class="mt-1"><i class="bi bi-circle-fill @aClass" style="font-size:10px;"></i></div>
                                <div>
                                    <div class="fw-medium">@a.ActionTaken <small class="text-muted">by @(a.User?.Email ?? "Unknown")</small></div>
                                    @if (!string.IsNullOrEmpty(a.Notes))
                                    {
                                        <small class="text-muted">@a.Notes</small>
                                    }
                                    <div class="text-muted small">@a.CreatedAt.ToString("MMM d, yyyy HH:mm")</div>
                                </div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted">No actions taken yet.</p>
                }
            </div>
        </div>
    </div>

    <!-- Actions Sidebar -->
    <div class="col-lg-4">
        @if (User.IsInRole("Admin") || User.IsInRole("Chairman") || User.IsInRole("Secretary"))
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-white">
                    <h6 class="mb-0 fw-bold">Take Action</h6>
                </div>
                <div class="card-body">
                    <form asp-action="AddWorkflowAction" method="post">
                        <input type="hidden" name="documentId" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="form-label text-muted small fw-bold">Action</label>
                            <select name="actionTaken" class="form-select" required>
                                <option value="Reviewed">Mark as Reviewed</option>
                                <option value="Approved">Approve</option>
                                <option value="Rejected">Reject</option>
                                <option value="Commented">Add Comment</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-muted small fw-bold">Notes</label>
                            <textarea name="notes" class="form-control" rows="3" placeholder="Optional notes…"></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Submit Action</button>
                    </form>
                </div>
            </div>
        }
        <div class="d-grid gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Edit Document</a>
            <a asp-action="Index" class="btn btn-light">Back to List</a>
        </div>
    </div>
</div>
