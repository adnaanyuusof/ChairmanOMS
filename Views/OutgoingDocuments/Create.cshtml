@model ChairmanOMS.Models.OutgoingDocument
@{
    ViewData["Title"] = "Issue Outgoing Document";
}

<div class="row justify-content-center mt-2">
    <div class="col-lg-9">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold">Issue Outgoing Document</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="ReferenceNumber" class="form-label text-muted small fw-bold"></label>
                            <input asp-for="ReferenceNumber" class="form-control" required placeholder="e.g. CSC/OUT/2026/015" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="DestinationInstitution" class="form-label text-muted small fw-bold"></label>
                            <input asp-for="DestinationInstitution" class="form-control" required placeholder="Ministry of Health" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Subject" class="form-label text-muted small fw-bold"></label>
                        <input asp-for="Subject" class="form-control" required />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="DateSent" class="form-label text-muted small fw-bold"></label>
                            <input asp-for="DateSent" type="date" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="LinkedIncomingDocumentId" class="form-label text-muted small fw-bold">Link to Incoming Document (Optional)</label>
                            <select asp-for="LinkedIncomingDocumentId" asp-items="@ViewBag.IncomingDocs" class="form-select border-start border-4 border-primary">
                                <option value="">-- None --</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-muted small fw-bold">Attachment (PDF / DOCX)</label>
                        <input type="file" name="attachment" class="form-control" accept=".pdf,.docx,.doc" />
                    </div>
                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-light">Cancel</a>
                        <button type="submit" class="btn btn-success">Issue Document</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
