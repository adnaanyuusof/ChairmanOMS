@model ChairmanOMS.Models.Appointment
@{
    ViewData["Title"] = "Edit Appointment";
}

<div class="row justify-content-center mt-2">
    <div class="col-lg-9">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2 text-primary"></i>Edit Appointment</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>

                    <h6 class="fw-bold text-muted mb-3 border-bottom pb-2">Visitor Information</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="VisitorName" class="form-label text-muted small fw-bold">Visitor Name</label>
                            <input asp-for="VisitorName" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Organization" class="form-label text-muted small fw-bold">Organization</label>
                            <input asp-for="Organization" class="form-control" required />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Phone" class="form-label text-muted small fw-bold">Phone Number</label>
                            <input asp-for="Phone" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Email" class="form-label text-muted small fw-bold">Email</label>
                            <input asp-for="Email" type="email" class="form-control" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Purpose" class="form-label text-muted small fw-bold">Purpose</label>
                        <textarea asp-for="Purpose" class="form-control" rows="2" required></textarea>
                    </div>

                    <h6 class="fw-bold text-muted mb-3 border-bottom pb-2 mt-4">Scheduling</h6>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="AppointmentDate" class="form-label text-muted small fw-bold">Date</label>
                            <input asp-for="AppointmentDate" type="date" class="form-control" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="StartTime" class="form-label text-muted small fw-bold">Start Time</label>
                            <input asp-for="StartTime" type="time" class="form-control" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="EndTime" class="form-label text-muted small fw-bold">End Time</label>
                            <input asp-for="EndTime" type="time" class="form-control" required />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Masuulka" class="form-label text-muted small fw-bold">Masuulka</label>
                            <input asp-for="Masuulka" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Priority" class="form-label text-muted small fw-bold">Priority</label>
                            <select asp-for="Priority" class="form-select">
                                <option value="Normal">🟢 Normal</option>
                                <option value="Urgent">🔴 Urgent</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-muted small fw-bold">Update Attachment (Optional)</label>
                        <input type="file" name="attachment" class="form-control" accept=".pdf,.docx,.doc,.jpg,.png" />
                        @if (!string.IsNullOrEmpty(Model.AttachmentPath))
                        {
                            <small class="text-muted d-block mt-1">Current: <a href="@Model.AttachmentPath" target="_blank">View File</a></small>
                        }
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-light">Cancel</a>
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
