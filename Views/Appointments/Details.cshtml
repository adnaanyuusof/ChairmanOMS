@model ChairmanOMS.Models.Appointment
@{
    ViewData["Title"] = "Appointment Details";
    var statusColor = Model.Status == "Approved" ? "bg-success" :
                      Model.Status == "Pending" ? "bg-warning text-dark" :
                      Model.Status == "Rejected" ? "bg-danger" :
                      Model.Status == "Completed" ? "bg-primary" : "bg-secondary";
}

<div class="row g-4">
    <!-- Left: Details -->
    <div class="col-lg-8">
        <!-- Main Info -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold"><i class="bi bi-person-lines-fill me-2 text-primary"></i>Appointment Details</h5>
                <div class="d-flex gap-2 align-items-center">
                    @if (Model.Priority == "Urgent")
                    {
                        <span class="badge bg-danger">🔴 Urgent</span>
                    }
                    <span class="badge @statusColor">@Model.Status</span>
                </div>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Visitor Name</dt>
                    <dd class="col-sm-8 fw-medium">@Model.VisitorName</dd>

                    <dt class="col-sm-4 text-muted">Organization</dt>
                    <dd class="col-sm-8">@Model.Organization</dd>

                    <dt class="col-sm-4 text-muted">Phone</dt>
                    <dd class="col-sm-8">@Model.Phone</dd>

                    @if (!string.IsNullOrEmpty(Model.Email))
                    {
                        <dt class="col-sm-4 text-muted">Email</dt>
                        <dd class="col-sm-8">@Model.Email</dd>
                    }

                    <dt class="col-sm-4 text-muted">Purpose</dt>
                    <dd class="col-sm-8">@Model.Purpose</dd>

                    @if (!string.IsNullOrEmpty(Model.Masuulka))
                    {
                        <dt class="col-sm-4 text-muted">Masuulka</dt>
                        <dd class="col-sm-8">@Model.Masuulka</dd>
                    }

                    <dt class="col-sm-4 text-muted">Date</dt>
                    <dd class="col-sm-8">@Model.AppointmentDate.ToLongDateString()</dd>

                    <dt class="col-sm-4 text-muted">Time</dt>
                    <dd class="col-sm-8">@Model.StartTime.ToString(@"hh\:mm") – @Model.EndTime.ToString(@"hh\:mm")</dd>

                    <dt class="col-sm-4 text-muted">Booked By</dt>
                    <dd class="col-sm-8">@(Model.CreatedBy?.Email ?? "—")</dd>

                    @if (!string.IsNullOrEmpty(Model.AttachmentPath))
                    {
                        <dt class="col-sm-4 text-muted">Attachment</dt>
                        <dd class="col-sm-8">
                            <a href="@Model.AttachmentPath" target="_blank" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-paperclip me-1"></i>View Document
                            </a>
                        </dd>
                    }
                </dl>
            </div>
        </div>

        <!-- Visitor Check-In -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white">
                <h6 class="mb-0 fw-bold"><i class="bi bi-door-open me-2"></i>Visitor Check-In</h6>
            </div>
            <div class="card-body">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div>
                        <strong>Status: </strong>
                        <span class="badge @(Model.VisitorStatus == "Arrived" ? "bg-success" : Model.VisitorStatus == "No-show" ? "bg-danger" : "bg-secondary")">
                            @(string.IsNullOrEmpty(Model.VisitorStatus) ? "Not Set" : Model.VisitorStatus)
                        </span>
                    </div>
                    @if (Model.CheckInTime.HasValue)
                    {
                        <div><strong>Check-in:</strong> @Model.CheckInTime.Value.ToLocalTime().ToString("HH:mm")</div>
                    }
                    @if (Model.CheckOutTime.HasValue)
                    {
                        <div><strong>Check-out:</strong> @Model.CheckOutTime.Value.ToLocalTime().ToString("HH:mm")</div>
                    }
                </div>
                @if ((User.IsInRole("Admin") || User.IsInRole("Secretary")) && Model.Status == "Approved")
                {
                    <div class="d-flex gap-2">
                        <form asp-action="CheckIn" method="post">
                            <input type="hidden" name="appointmentId" value="@Model.Id" />
                            <input type="hidden" name="visitorStatus" value="Arrived" />
                            <button class="btn btn-sm btn-success">✅ Mark Arrived</button>
                        </form>
                        <form asp-action="CheckIn" method="post">
                            <input type="hidden" name="appointmentId" value="@Model.Id" />
                            <input type="hidden" name="visitorStatus" value="No-show" />
                            <button class="btn btn-sm btn-danger">❌ Mark No-show</button>
                        </form>
                        @if (Model.VisitorStatus == "Arrived" && !Model.CheckOutTime.HasValue)
                        {
                            <form asp-action="CheckOut" method="post">
                                <input type="hidden" name="appointmentId" value="@Model.Id" />
                                <button class="btn btn-sm btn-outline-secondary">🚪 Check Out</button>
                            </form>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Meeting Notes -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white">
                <h6 class="mb-0 fw-bold"><i class="bi bi-journal-text me-2"></i>Meeting Notes</h6>
            </div>
            <div class="card-body">
                @if (Model.MeetingNotes.Any())
                {
                    @foreach (var note in Model.MeetingNotes.OrderByDescending(n => n.CreatedAt))
                    {
                        <div class="border rounded p-3 mb-3 bg-light">
                            <p class="mb-1">@note.Notes</p>
                            @if (!string.IsNullOrEmpty(note.Decision))
                            {
                                <div class="mt-2">
                                    <strong class="text-success">Decision:</strong> <span>@note.Decision</span>
                                </div>
                            }
                            <small class="text-muted">by @(note.CreatedBy?.Email ?? "—") — @note.CreatedAt.ToLocalTime().ToString("MMM d, yyyy HH:mm")</small>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">No meeting notes yet.</p>
                }

                @if (User.IsInRole("Admin") || User.IsInRole("Chairman") || User.IsInRole("Secretary"))
                {
                    <form asp-action="AddNote" method="post" class="mt-3">
                        <input type="hidden" name="appointmentId" value="@Model.Id" />
                        <div class="mb-2">
                            <label class="form-label small fw-bold text-muted">Add Note</label>
                            <textarea name="notes" class="form-control" rows="3" required placeholder="Meeting notes…"></textarea>
                        </div>
                        <div class="mb-2">
                            <label class="form-label small fw-bold text-muted">Decision / Outcome (Optional)</label>
                            <input name="decision" class="form-control" placeholder="e.g. Approved request, Follow-up scheduled…" />
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm">Save Note</button>
                    </form>
                }
            </div>
        </div>

        <!-- Status History -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h6 class="mb-0 fw-bold"><i class="bi bi-clock-history me-2"></i>Status History</h6>
            </div>
            <div class="card-body pb-0">
                @if (Model.Logs.Any())
                {
                    <ul class="list-unstyled">
                        @foreach (var log in Model.Logs.OrderByDescending(l => l.ChangedAt))
                        {
                            var lColor = log.Status == "Approved" ? "text-success" : log.Status == "Rejected" ? "text-danger" : "text-info";
                            <li class="mb-3 d-flex gap-3">
                                <div class="mt-1"><i class="bi bi-circle-fill @lColor" style="font-size:10px;"></i></div>
                                <div>
                                    <div class="fw-medium">@log.Status <small class="text-muted">by @(log.ChangedBy?.Email ?? "System")</small></div>
                                    @if (!string.IsNullOrEmpty(log.Notes)) { <small class="text-muted">@log.Notes</small> }
                                    <div class="text-muted small">@log.ChangedAt.ToLocalTime().ToString("MMM d, yyyy HH:mm")</div>
                                </div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted">No history available.</p>
                }
            </div>
        </div>
    </div>

    <!-- Right: Actions Sidebar -->
    <div class="col-lg-4">
        <!-- Approval Workflow -->
        @if (User.IsInRole("Admin") || User.IsInRole("Chairman"))
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-white">
                    <h6 class="mb-0 fw-bold">Approval Action</h6>
                </div>
                <div class="card-body">
                    <form asp-action="UpdateStatus" method="post">
                        <input type="hidden" name="appointmentId" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">New Status</label>
                            <select name="newStatus" class="form-select" required>
                                <option value="Approved">✅ Approve</option>
                                <option value="Rejected">❌ Reject</option>
                                <option value="Completed">🏁 Mark Completed</option>
                                <option value="Cancelled">🚫 Cancel</option>
                                <option value="Pending">⏳ Reset to Pending</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Notes</label>
                            <textarea name="notes" class="form-control" rows="2" placeholder="Optional reason…"></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Submit Decision</button>
                    </form>
                </div>
            </div>
        }

        <div class="d-grid gap-2">
            @if (User.IsInRole("Admin") || User.IsInRole("Secretary"))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
                    <i class="bi bi-pencil me-1"></i>Edit Appointment
                </a>
            }
            <a asp-action="Index" class="btn btn-light">Back to List</a>
            @if (User.IsInRole("Admin"))
            {
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                      onsubmit="return confirm('Permanently delete this appointment?');">
                    <button type="submit" class="btn btn-danger w-100">
                        <i class="bi bi-trash me-1"></i>Delete
                    </button>
                </form>
            }
        </div>
    </div>
</div>
