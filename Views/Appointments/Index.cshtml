@model IEnumerable<ChairmanOMS.Models.Appointment>
@{
    ViewData["Title"] = "Appointments";
}

<div class="d-flex justify-content-between align-items-center mb-3 mt-2">
    <h2 class="fw-bold mb-0">Appointments & Meetings</h2>
    <div class="d-flex gap-2">
        <a asp-action="Calendar" class="btn btn-outline-primary">
            <i class="bi bi-calendar3 me-1"></i> Calendar View
        </a>
        @if (User.IsInRole("Admin") || User.IsInRole("Secretary"))
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i> New Appointment
            </a>
        }
    </div>
</div>

<!-- Dashboard Stats -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="card-body py-2">
                <div class="fs-3 fw-bold text-primary">@ViewBag.TodayCount</div>
                <div class="text-muted small">Today's Appointments</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="card-body py-2">
                <div class="fs-3 fw-bold text-warning">@ViewBag.PendingCount</div>
                <div class="text-muted small">Pending Approval</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="card-body py-2">
                <div class="fs-3 fw-bold text-success">@ViewBag.UpcomingCount</div>
                <div class="text-muted small">Upcoming (Approved)</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="card-body py-2">
                <div class="fs-3 fw-bold text-info">@Model.Count()</div>
                <div class="text-muted small">Showing (Filtered)</div>
            </div>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <input name="search" value="@ViewBag.Search" class="form-control" placeholder="Search visitor, org, purpose…" />
            </div>
            <div class="col-md-2">
                <select name="status" class="form-select">
                    <option value="">All Statuses</option>
                    @foreach (var s in new[] { "Pending", "Approved", "Rejected", "Completed", "Cancelled" })
                    {
                        <option value="@s" selected="@(ViewBag.SelectedStatus == s ? "selected" : null)">@s</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <select name="priority" class="form-select">
                    <option value="">All Priorities</option>
                    <option value="Normal" selected="@(ViewBag.SelectedPriority == "Normal" ? "selected" : null)">Normal</option>
                    <option value="Urgent" selected="@(ViewBag.SelectedPriority == "Urgent" ? "selected" : null)">🔴 Urgent</option>
                </select>
            </div>
            <div class="col-md-2">
                <input type="date" name="date" value="@ViewBag.SelectedDate" class="form-control" />
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-fill">Filter</button>
                <a asp-action="Index" class="btn btn-light">Clear</a>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle small">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">Visitor</th>
                        <th>Organization</th>
                        <th>Purpose</th>
                        <th>Masuulka</th>
                        <th>Date</th>
                        <th>Time</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>Visitor Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model)
                    {
                        var sColor = a.Status == "Approved" ? "bg-success" :
                                     a.Status == "Pending" ? "bg-warning text-dark" :
                                     a.Status == "Rejected" ? "bg-danger" :
                                     a.Status == "Completed" ? "bg-primary" : "bg-secondary";
                        var pColor = a.Priority == "Urgent" ? "bg-danger" : "bg-secondary";
                        var vColor = a.VisitorStatus == "Arrived" ? "bg-success" :
                                     a.VisitorStatus == "No-show" ? "bg-danger" : "bg-light text-muted";
                        <tr class="@(a.Priority == "Urgent" ? "table-warning" : "")">
                            <td class="ps-3 fw-medium">@a.VisitorName</td>
                            <td>@a.Organization</td>
                            <td>@a.Purpose</td>
                            <td>@(string.IsNullOrEmpty(a.Masuulka) ? "—" : a.Masuulka)</td>
                            <td>@a.AppointmentDate.ToShortDateString()</td>
                            <td>@a.StartTime.ToString(@"hh\:mm") – @a.EndTime.ToString(@"hh\:mm")</td>
                            <td><span class="badge @pColor">@a.Priority</span></td>
                            <td><span class="badge @sColor">@a.Status</span></td>
                            <td>
                                <span class="badge @vColor">@(string.IsNullOrEmpty(a.VisitorStatus) ? "Not Set" : a.VisitorStatus)</span>
                            </td>
                            <td>
                                <div class="d-flex gap-1 flex-nowrap">
                                    <a asp-action="Details" asp-route-id="@a.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                    @if (User.IsInRole("Admin") || User.IsInRole("Secretary"))
                                    {
                                        <a asp-action="Edit" asp-route-id="@a.Id" class="btn btn-sm btn-outline-secondary">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                    }
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <form asp-action="Delete" asp-route-id="@a.Id" method="post"
                                              onsubmit="return confirm('Delete this appointment for @a.VisitorName?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="10" class="text-center text-muted py-5">No appointments found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
