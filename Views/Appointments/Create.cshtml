@model ChairmanOMS.Models.Appointment
@{
    ViewData["Title"] = "Book Appointment";
}

<div class="row justify-content-center mt-2">
    <div class="col-lg-9">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold"><i class="bi bi-calendar-plus me-2 text-primary"></i>Book New Appointment</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>

                    <!-- Visitor Info -->
                    <h6 class="fw-bold text-muted mb-3 border-bottom pb-2">Visitor Information</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="VisitorName" class="form-label text-muted small fw-bold">Visitor Name <span class="text-danger">*</span></label>
                            <input asp-for="VisitorName" class="form-control" required placeholder="Full Name" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Organization" class="form-label text-muted small fw-bold">Organization / Ministry <span class="text-danger">*</span></label>
                            <input asp-for="Organization" class="form-control" required placeholder="e.g. Ministry of Finance" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Phone" class="form-label text-muted small fw-bold">Phone Number <span class="text-danger">*</span></label>
                            <input asp-for="Phone" class="form-control" required placeholder="063xxxxxxx" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Email" class="form-label text-muted small fw-bold">Email (Optional)</label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="visitor@example.com" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Purpose" class="form-label text-muted small fw-bold">Purpose of Meeting <span class="text-danger">*</span></label>
                        <textarea asp-for="Purpose" class="form-control" rows="2" required placeholder="Briefly describe the reason for the meeting…"></textarea>
                    </div>

                    <!-- Scheduling -->
                    <h6 class="fw-bold text-muted mb-3 border-bottom pb-2 mt-4">Scheduling</h6>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="AppointmentDate" class="form-label text-muted small fw-bold">Appointment Date <span class="text-danger">*</span></label>
                            <input asp-for="AppointmentDate" type="date" class="form-control" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="StartTime" class="form-label text-muted small fw-bold">Start Time <span class="text-danger">*</span></label>
                            <input asp-for="StartTime" type="time" class="form-control" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="EndTime" class="form-label text-muted small fw-bold">End Time <span class="text-danger">*</span></label>
                            <input asp-for="EndTime" type="time" class="form-control" required />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Masuulka" class="form-label text-muted small fw-bold">Masuulka</label>
                            <input asp-for="Masuulka" class="form-control" placeholder="Name of the official" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Priority" class="form-label text-muted small fw-bold">Priority</label>
                            <select asp-for="Priority" class="form-select">
                                <option value="Normal">🟢 Normal</option>
                                <option value="Urgent">🔴 Urgent</option>
                            </select>
                        </div>
                    </div>

                    <!-- Attachment -->
                    <div class="mb-4">
                        <label class="form-label text-muted small fw-bold">Related Document (Optional)</label>
                        <input type="file" name="attachment" class="form-control" accept=".pdf,.docx,.doc,.jpg,.png" />
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-light">Cancel</a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-calendar-check me-1"></i>Book Appointment
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
