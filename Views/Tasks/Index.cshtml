@model IEnumerable<ChairmanOMS.Models.TaskItem>
@{
    ViewData["Title"] = "Tasks";
}

<div class="d-flex justify-content-between align-items-center mb-3 mt-2">
    <h2 class="fw-bold mb-0">Task Management</h2>
    <a asp-action="Create" class="btn btn-warning text-dark fw-medium">
        <i class="bi bi-plus-lg me-1"></i> New Task
    </a>
</div>

<div class="row">
    @foreach (var task in Model)
    {
        var borderClass = task.IsCompleted ? "border-success" : task.DueDate.HasValue && task.DueDate.Value < DateTime.Now ? "border-danger" : "border-warning";
        var titleClass = task.IsCompleted ? "text-decoration-line-through text-muted" : "text-dark";
        
        <div class="col-md-6 col-lg-4 mb-3">
            <div class="card h-100 shadow-sm @borderClass" style="border-left-width: 4px;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h6 class="mb-0 fw-bold @titleClass">@task.Title</h6>
                        <form asp-action="ToggleComplete" asp-route-id="@task.Id" method="post">
                            <button type="submit" class="btn btn-sm btn-link p-0 text-decoration-none">
                                @if(task.IsCompleted)
                                {
                                    <i class="bi bi-check-circle-fill fs-5 text-success"></i>
                                }
                                else
                                {
                                    <i class="bi bi-circle fs-5 text-muted"></i>
                                }
                            </button>
                        </form>
                    </div>
                    @if (!string.IsNullOrEmpty(task.Description))
                    {
                        <p class="small text-muted mb-3" style="min-height: 40px;">@task.Description</p>
                    }
                    else
                    {
                         <p class="small text-muted mb-3 fst-italic" style="min-height: 40px;">No description provided.</p>
                    }
                    
                    <hr class="my-2" />
                    
                    <div class="d-flex justify-content-between align-items-center mt-2 small">
                        <span class="text-muted"><i class="bi bi-person me-1"></i>@(task.AssignedToUser?.Email?.Split('@')[0] ?? "Unassigned")</span>
                        @if (task.DueDate.HasValue)
                        {
                            var d = task.DueDate.Value;
                            var badgeClass = task.IsCompleted ? "bg-light text-muted border" : d < DateTime.Now ? "bg-danger" : "bg-light text-dark border";
                            <span class="badge @badgeClass"><i class="bi bi-calendar me-1"></i>@d.ToString("MMM d")</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="col-12 py-5 text-center text-muted">
            <div class="fs-1 mb-3"><i class="bi bi-check2-all"></i></div>
            <p>You have no assigned tasks. Enjoy your day!</p>
        </div>
    }
</div>
